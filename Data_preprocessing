 Problem Statement 2: Search Query Keyword Analysis
import string

 Input: Search query
search_query = "Buy mobile phone buy phone online"
print(f"\nInput: \"{search_query}\"")

Step 1: Convert to lowercase
lowercase_query = search_query.lower()

 Step 2: Remove punctuation
cleaned_query = lowercase_query.translate(str.maketrans('', '', string.punctuation))

 Step 3: Split into keywords
keywords = cleaned_query.split()

Step 4: Count frequency of each keyword
from collections import Counter
keyword_freq = Counter(keywords)

 Step 5: Display only keywords searched more than once
filtered_keywords = {word: count for word, count in keyword_freq.items() if count > 1}

 Sort by word for consistent output
result_2 = dict(sorted(filtered_keywords.items()))
print(f"\nOutput: {result_2}")

